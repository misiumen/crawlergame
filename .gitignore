# Saves + per-user settings are local. Both old (revamp_*) and new
# (dungeon_kraulem_*) names are ignored so a migration leftover never
# accidentally gets committed.
savegame.json
revamp_save.json
settings_revamp.json
dungeon_kraulem_save.json
dungeon_kraulem_save_*.json
dungeon_kraulem_settings.json
dungeon_kraulem_runs.json

